@* 
  Veritabanına bir yansıma yapılacağı için sayfa Makale modeline sıkıca bağlanır (Strongly Typed View).
  Böylece asp-for="..." özellikleri otomatik Makale sınıfından özellik (Baslik, Icerik vb.) bekler. 
*@
@model BlogProjesi.Models.Makale
@{
    ViewData["Title"] = "Yeni Makale Ekle";
}

<div class="row mt-4">
    <div class="col-md-8 mx-auto">
        <h3>Yeni Makale Ekle</h3>
        <hr />
        <!-- POST Form: Tag helper asp-action="Ekle" ile MakaleController içindeki [HttpPost] Ekle metoduna gider  -->
        <form asp-action="Ekle" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            
            <div class="mb-3">
                @* asp-for="Baslik": Model.Baslik'ı temsil eder. Name ID özelliklerini kendi otomatik doldurur. *@
                <label asp-for="Baslik" class="form-label">Makale Başlığı</label>
                <input asp-for="Baslik" class="form-control" />
                @* asp-validation-for: C#'taki [Required] hata mesajını boş bırakıldığında anında ekrana basar. (JavaScript Yardımıyla) *@
                <span asp-validation-for="Baslik" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ResimUrl" class="form-label">Resim URL (Link)</label>
                <input asp-for="ResimUrl" class="form-control" placeholder="Örn: https://example.com/resim.jpg" />
                <span asp-validation-for="ResimUrl" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Icerik" class="form-label">Makale İçeriği</label>
                <textarea asp-for="Icerik" class="form-control" rows="5"></textarea>
                <span asp-validation-for="Icerik" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary">Kaydet ve Yayınla</button>
            <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">İptal</a>
        </form>
    </div>
</div>

@section Scripts {
    @* Sayfa submit olmadan önce ("Frontend" Anında Validasyon) tarayıcıda JavaScript kurallarını işletmek için Microsoft'un Partial dosyası çağrılır. Sürekli Server'a post atmasını önler. *@
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
